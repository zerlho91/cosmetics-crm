# ===== Supabase Postgres 연결 =====
# Supabase 대시보드 > Project Settings > Database > Connection string > "URI" 복사
# (서버리스/Vercel 에서는 반드시 6543 포트의 "Transaction pooler" URI 사용 권장)
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# ===== AI (Claude / Anthropic) =====
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxx
# 사용할 모델 (선택, 기본값: claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

# ===== 로컬 개발 서버 포트 (선택) =====
PORT=3001
